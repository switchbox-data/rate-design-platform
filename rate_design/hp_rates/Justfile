# Derive seasonal TOU tariffs from MC rates (no dependency on calibrated flat run outputs).
# Uses a pre-calibrated tariff only to extract the fixed charge.
# Set base_pattern to "default" to read from the default-structure tariff instead of flat.

# Writes {tou_tariff_key}.json and creates {tou_tariff_key}_supply.json with updated label.
create-seasonal-tou-tariffs base_pattern="flat":
    #!/usr/bin/env bash
    set -euo pipefail
    ref_tariff="{{ path_tariffs_electric }}/{{ utility }}_{{ base_pattern }}.json"
    echo ">> create-seasonal-tou-tariffs: deriving TOU from MC (fixed charge from ${ref_tariff})" >&2
    just create-seasonal-tou {{ tou_tariff_key }} "${ref_tariff}"
    # Create supply version by copying JSON and updating label
    base_path="{{ path_tariffs_electric }}/{{ tou_tariff_key }}.json"
    supply_path="{{ path_tariffs_electric }}/{{ tou_tariff_key }}_supply.json"
    supply_label="{{ tou_tariff_key }}_supply"
    uv run python3 -c \
        "import json; \
        t = json.load(open('${base_path}')); \
        t['items'][0]['label'] = '${supply_label}'; \
        t['items'][0].get('name') and t['items'][0].update({'name': '${supply_label}'}); \
        f = open('${supply_path}', 'w'); json.dump(t, f, indent=2); f.write('\n'); f.close(); \
        print('Created ${supply_path}')"
    echo ">> create-seasonal-tou-tariffs: wrote {{ tou_tariff_key }}.json and {{ tou_tariff_key }}_supply.json" >&2

create-seasonal-tou key=tou_tariff_key reference_tariff="" run_dir="" has_hp="true":
    just -f {{ path_repo }}/utils/Justfile create-seasonal-tou \
      "{{ path_supply_energy_mc }}" \
      "{{ path_supply_capacity_mc }}" \
      "{{ state_upper }}" \
      "{{ utility }}" \
      "{{ year }}" \
      "{{ path_dist_and_sub_tx_mc }}" \
      "{{ path_utility_assignment }}" \
      "{{ path_resstock_release }}" \
      "{{ upgrade }}" \
      "{{ path_electric_utility_stats }}" \
      "{{ key }}" \
      "{{ path_config }}" \
      "{{ path_periods_yaml }}" \
      "{{ reference_tariff }}" \
      "{{ run_dir }}" \
      "{{ path_bulk_tx_mc }}" \
      "{{ has_hp }}"

sweep-tou-window run_dir="" output_dir="" no_write_yaml="" has_hp="true":
    uv run python {{ path_repo }}/utils/pre/derive_seasonal_tou_window.py \
      --path-supply-energy-mc "{{ path_supply_energy_mc }}" \
      --path-supply-capacity-mc "{{ path_supply_capacity_mc }}" \
      --state "{{ state_upper }}" \
      --utility "{{ utility }}" \
      --year "{{ year }}" \
      --path-dist-and-sub-tx-mc "{{ path_dist_and_sub_tx_mc }}" \
      --path-utility-assignment "{{ path_utility_assignment }}" \
      --resstock-base "{{ path_resstock_release }}" \
      --upgrade "{{ upgrade }}" \
      --path-electric-utility-stats "{{ path_electric_utility_stats }}" \
      --has-hp "{{ has_hp }}" \
      --periods-yaml "{{ path_periods_yaml }}" \
      {{ if run_dir != "" { "--run-dir \"" + run_dir + "\"" } else { "" } }} \
      {{ if path_bulk_tx_mc != "" { "--path-bulk-tx-mc \"" + path_bulk_tx_mc + "\"" } else { "" } }} \
      {{ if output_dir != "" { "--output-dir \"" + output_dir + "\"" } else { "" } }} \
      {{ if no_write_yaml == "true" { "--no-write-yaml" } else { "" } }}

sweep-tou-window-all run_dir="" output_dir="" no_write_yaml="":
    #!/usr/bin/env bash
    set -euo pipefail
    IFS=',' read -ra utils <<< "{{ utilities }}"
    for util in "${utils[@]}"; do
        echo ">> sweep-tou-window for utility: $util" >&2
        UTILITY="$util" just sweep-tou-window "{{ run_dir }}" "{{ output_dir }}" "{{ no_write_yaml }}"
    done

