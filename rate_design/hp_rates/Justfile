    run18_dir=$(bash "{{ latest_output }}" "{{ path_scenario_config }}" 18)
    echo ">> run-20: resolved run-18 output → ${run18_dir}" >&2
    just copy-calibrated-tariff-from-run "${run18_dir}"
    just run-scenario 20

# Electric-heating / non-electric-heating subclass RR (runs 29–30).

# Uses run 1+2 BAT with BAT_percustomer (matches residual_allocation_delivery: percustomer for those runs).
compute-electric-heating-subclass-rev-requirements:
    #!/usr/bin/env bash
    set -euo pipefail
    run1_dir=$(bash "{{ latest_output }}" "{{ path_scenario_config }}" 1)
    run2_dir=$(bash "{{ latest_output }}" "{{ path_scenario_config }}" 2)
    read -r base_rr differentiated_rr < <(uv run python3 "{{ path_repo }}/utils/mid/resolve_rr_paths.py" "{{ path_scenario_config }}" --subclass-run-num 29)
    read -r group_col group_value_to_subclass < <(uv run python3 "{{ path_repo }}/utils/mid/resolve_subclass_config.py" "{{ path_scenario_config }}" --run-num 29)
    echo ">> compute-electric-heating-subclass-rev-requirements: run-1 (delivery) → ${run1_dir}" >&2
    echo ">> compute-electric-heating-subclass-rev-requirements: run-2 (delivery+supply) → ${run2_dir}" >&2
    echo ">> base_rr: ${base_rr}" >&2
    echo ">> differentiated_rr: ${differentiated_rr}" >&2
    echo ">> group_col: ${group_col}" >&2
    echo ">> group_value_to_subclass: ${group_value_to_subclass}" >&2
    just compute-subclass-rr "${run1_dir}" "{{ path_scenario_config }}" \
      "1" "${group_col}" \
      "${differentiated_rr}" \
      "${base_rr}" \
      "${group_value_to_subclass}" \
      "${base_rr}" \
      "${run2_dir}"

