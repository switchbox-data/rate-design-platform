    #!/usr/bin/env bash
    set -euo pipefail
    run2_dir=$(bash "{{ latest_output }}" "{{ path_scenario_config }}" 2)
    echo ">> run-4: resolved run-2 output → ${run2_dir}" >&2
    just copy-calibrated-tariff-from-run "${run2_dir}"
    just run-scenario 4

