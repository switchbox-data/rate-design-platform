    just copy-default-structure-to-non-electric-heating-all
    just create-seasonal-tou-tariffs {{ base_tariff_pattern }}
    just validate-config

run-all-utilities-sequential:
    #!/usr/bin/env bash
    set -euo pipefail
    : "${RDP_BATCH:?Set RDP_BATCH before running (e.g. ny_20260305c_r1-8)}"
    export RDP_BATCH
    echo ">> run-all-utilities-sequential [${RDP_BATCH}]" >&2
    IFS=',' read -ra utils <<< "{{ utilities }}"
    for util in "${utils[@]}"; do
        echo ">> ======================================" >&2
        echo ">> Running utility: $util" >&2
        echo ">> ======================================" >&2
        UTILITY="$util" just all-pre
        UTILITY="$util" just run-all-sequential
    done

run-all-sequential:
    #!/usr/bin/env bash
    set -euo pipefail
    : "${RDP_BATCH:?Set RDP_BATCH before running (e.g. ny_20260305c_r1-8)}"
    export RDP_BATCH
    echo ">> run-all-sequential [${RDP_BATCH}]" >&2
    just run-1
    just run-2
    just compute-subclass-rev-requirements
    just run-3
    just run-4
    just run-5
    just run-6
    just run-7
    just run-8
    just run-9
    just run-10
    just run-11
    just run-12
    just run-13
    just run-14
    just run-15
    just run-16
    just run-17
    just run-18
    just run-19
    just run-20
    if uv run python3 "{{ path_repo }}/utils/mid/scenario_has_run_num.py" "{{ path_scenario_config }}" 29; then
        just compute-electric-heating-subclass-rev-requirements
        just run-21
        just run-22
        just run-23
        just run-24
        just run-29
        just run-30
        just run-31
        just run-32
        just run-33
        just run-34
        just run-35
        just run-36
    fi

run-all-parallel-tracks:
    #!/usr/bin/env bash
    set -euo pipefail
    : "${RDP_BATCH:?Set RDP_BATCH before running (e.g. ny_20260305c_r1-8)}"
    export RDP_BATCH
    WORKERS=$(( $(nproc) / 2 ))
    [ "$WORKERS" -lt 1 ] && WORKERS=1
    export RDP_NUM_WORKERS="$WORKERS"
    echo ">> run-all-parallel-tracks [${RDP_BATCH}]: ${WORKERS} workers/track on $(nproc) total vCPUs" >&2

    just run-1 & PID1=$!
    just run-2 & PID2=$!
    wait $PID1 || { echo "ERROR: run-1 failed" >&2; exit 1; }
    wait $PID2 || { echo "ERROR: run-2 failed" >&2; exit 1; }

    just compute-subclass-rev-requirements

    just run-3 & PID3=$!
    just run-4 & PID4=$!
    wait $PID3 || { echo "ERROR: run-3 failed" >&2; exit 1; }
    wait $PID4 || { echo "ERROR: run-4 failed" >&2; exit 1; }

    just run-5 & PID5=$!
    just run-6 & PID6=$!
    wait $PID5 || { echo "ERROR: run-5 failed" >&2; exit 1; }
    wait $PID6 || { echo "ERROR: run-6 failed" >&2; exit 1; }

    just run-7 & PID7=$!
    just run-8 & PID8=$!
    wait $PID7 || { echo "ERROR: run-7 failed" >&2; exit 1; }
    wait $PID8 || { echo "ERROR: run-8 failed" >&2; exit 1; }

    just run-9 & PID9=$!
    just run-10 & PID10=$!
    wait $PID9 || { echo "ERROR: run-9 failed" >&2; exit 1; }
    wait $PID10 || { echo "ERROR: run-10 failed" >&2; exit 1; }

    just run-11 & PID11=$!
    just run-12 & PID12=$!
    wait $PID11 || { echo "ERROR: run-11 failed" >&2; exit 1; }
    wait $PID12 || { echo "ERROR: run-12 failed" >&2; exit 1; }

    just run-13 & PID13=$!
    just run-14 & PID14=$!
    wait $PID13 || { echo "ERROR: run-13 failed" >&2; exit 1; }
    wait $PID14 || { echo "ERROR: run-14 failed" >&2; exit 1; }

    just run-15 & PID15=$!
    just run-16 & PID16=$!
    wait $PID15 || { echo "ERROR: run-15 failed" >&2; exit 1; }
    wait $PID16 || { echo "ERROR: run-16 failed" >&2; exit 1; }

    just run-17 & PID17=$!
    just run-18 & PID18=$!
    wait $PID17 || { echo "ERROR: run-17 failed" >&2; exit 1; }
    wait $PID18 || { echo "ERROR: run-18 failed" >&2; exit 1; }

    just run-19 & PID19=$!
    just run-20 & PID20=$!
    wait $PID19 || { echo "ERROR: run-19 failed" >&2; exit 1; }
    wait $PID20 || { echo "ERROR: run-20 failed" >&2; exit 1; }

    if uv run python3 "{{ path_repo }}/utils/mid/scenario_has_run_num.py" "{{ path_scenario_config }}" 29; then
        just compute-electric-heating-subclass-rev-requirements
        # 21+22 (hp_seasonal_epmc precalc), 29+30 (elec_heat flat precalc), and 33+34
        # (elec_heat seasonal precalc) are independent; 29-36 use percustomer allocation
        just run-21 & PID21=$!
        just run-22 & PID22=$!
        just run-29 & PID29=$!
        just run-30 & PID30=$!
        just run-33 & PID33=$!
        just run-34 & PID34=$!
        wait $PID21 || { echo "ERROR: run-21 failed" >&2; exit 1; }
        wait $PID22 || { echo "ERROR: run-22 failed" >&2; exit 1; }
        wait $PID29 || { echo "ERROR: run-29 failed" >&2; exit 1; }
        wait $PID30 || { echo "ERROR: run-30 failed" >&2; exit 1; }
        wait $PID33 || { echo "ERROR: run-33 failed" >&2; exit 1; }
        wait $PID34 || { echo "ERROR: run-34 failed" >&2; exit 1; }
        # 23+24 depend on 21+22 calibrated tariff; 31+32 depend on 29+30 calibrated
        # tariff; 35+36 depend on 33+34 calibrated tariff
        just run-23 & PID23=$!
        just run-24 & PID24=$!
        just run-31 & PID31=$!
        just run-32 & PID32=$!
        just run-35 & PID35=$!
        just run-36 & PID36=$!
        wait $PID23 || { echo "ERROR: run-23 failed" >&2; exit 1; }
        wait $PID24 || { echo "ERROR: run-24 failed" >&2; exit 1; }
        wait $PID31 || { echo "ERROR: run-31 failed" >&2; exit 1; }
        wait $PID32 || { echo "ERROR: run-32 failed" >&2; exit 1; }
        wait $PID35 || { echo "ERROR: run-35 failed" >&2; exit 1; }
        wait $PID36 || { echo "ERROR: run-36 failed" >&2; exit 1; }
        echo ">> run-all-parallel-tracks: all 36 runs complete" >&2
    else
        echo ">> run-all-parallel-tracks: all 20 runs complete" >&2
    fi

run-subset runs:
    #!/usr/bin/env bash
    set -euo pipefail
    : "${RDP_BATCH:?Set RDP_BATCH before running (e.g. ny_20260305c_r1-8)}"
    export RDP_BATCH
    echo ">> run-subset [${RDP_BATCH}]: runs={{ runs }}" >&2
    IFS=',' read -ra nums <<< "{{ runs }}"
    for num in "${nums[@]}"; do
        echo ">> run-subset: run-${num}" >&2
        just "run-${num}"
    done

