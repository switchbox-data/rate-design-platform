# MD heat pump rate design tasks.
# Thin wrapper: sets state defaults, loads state.env, imports shared recipes.
#
# Usage (from rate_design/hp_rates/):
#   just -f md/Justfile create-supply-energy-mc bge 2023
#   just -f md/Justfile create-bulk-tx-mc-data bge 2025
#   just -f md/Justfile create-bulk-tx-mc-data-all
#   just -f md/Justfile create-dist-and-sub-tx-mc-data        # uses state.env UTILITY
# Or via dispatch:
#   just s md create-bulk-tx-mc-data bge 2025
#   just s md create-dist-and-sub-tx-mc-data

set dotenv-path := "state.env"

state := env_var_or_default('STATE', 'md')
utility := env_var_or_default('UTILITY', 'bge')

import '../Justfile'

# =============================================================================
# MD-only: ISO-native load source for sub-TX/DX marginal costs
#
# MD reads PJM-native utility loads (data/pjm/hourly_demand/) instead of the
# shared EIA default. Layout: utility={slug}/year=YYYY/month=MM/data.parquet,
# which the ISO-native path handling in generate_utility_tx_dx_mc.py reads
# without a region= filter.
# =============================================================================

path_s3_utility_loads := "s3://data.sb/pjm/hourly_demand/utilities/"

# =============================================================================
# MD-only: supply energy marginal costs (PJM LMP)
# =============================================================================

# Available years from PJM LMP download (2018-2025, excluding incomplete 2026).
pjm_lmp_years := "2018 2019 2020 2021 2022 2023 2024 2025"

# All MD utilities (canonical std_names) and their PJM zones (IOUs + co-ops + municipals).
# IOUs: bge (BGE), pepco (PEPCO), dpl (DPL), poted (APS)
# Co-ops: smeco (PEPCO), choptank (DPL), somerset_rec (APS)
# Municipals: hagerstown_muni (APS), easton_muni (DPL), berlin_muni (DPL)
pjm_utilities := "bge pepco dpl poted smeco choptank somerset_rec hagerstown_muni easton_muni berlin_muni"

# Generate supply energy MC for one MD utility and one year.
#
#   just -f md/Justfile create-supply-energy-mc bge 2023
# just -f md/Justfile create-supply-energy-mc bge 2023 --upload
create-supply-energy-mc utility year *extra_args:
    uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_supply_energy_mc.py \
      --iso pjm \
      --utility {{ utility }} \
      --year {{ year }} \
      {{ extra_args }}

# Generate supply energy MC for one utility across all available years.
#
#   just -f md/Justfile create-supply-energy-mc-all-years bge
# just -f md/Justfile create-supply-energy-mc-all-years bge --upload
create-supply-energy-mc-all-years utility *extra_args:
    #!/usr/bin/env bash
    set -euo pipefail
    for year in {{ pjm_lmp_years }}; do
        echo ">> Generating PJM supply energy MC: utility={{ utility }} year=${year}" >&2
        uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_supply_energy_mc.py \
          --iso pjm \
          --utility {{ utility }} \
          --year "${year}" \
          {{ extra_args }}
    done
    echo ">> Done: {{ utility }} all years" >&2

# Generate supply energy MC for all MD utilities for one year.
#
#   just -f md/Justfile create-supply-energy-mc-all 2023
# just -f md/Justfile create-supply-energy-mc-all 2023 --upload
create-supply-energy-mc-all year *extra_args:
    #!/usr/bin/env bash
    set -euo pipefail
    for utility in {{ pjm_utilities }}; do
        echo ">> Generating PJM supply energy MC: utility=${utility} year={{ year }}" >&2
        uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_supply_energy_mc.py \
          --iso pjm \
          --utility "${utility}" \
          --year {{ year }} \
          {{ extra_args }}
    done
    echo ">> Done: all utilities year={{ year }}" >&2

# Generate supply energy MC for ALL utilities across ALL available years.
# This is the full backfill. Runs sequentially utility-by-utility, year-by-year.
#
#   just -f md/Justfile create-supply-energy-mc-full-backfill
# just -f md/Justfile create-supply-energy-mc-full-backfill --upload
create-supply-energy-mc-full-backfill *extra_args:
    #!/usr/bin/env bash
    set -euo pipefail
    for utility in {{ pjm_utilities }}; do
        for year in {{ pjm_lmp_years }}; do
            echo ">> Generating PJM supply energy MC: utility=${utility} year=${year}" >&2
            uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_supply_energy_mc.py \
              --iso pjm \
              --utility "${utility}" \
              --year "${year}" \
              {{ extra_args }}
        done
    done
    echo ">> Done: full backfill" >&2

# =============================================================================
# MD-only: bulk transmission marginal costs (PJM NITS + PCAF)
#
# Uses NITS rates from data/pjm/bulk_tx/nits/nits_rates.csv and PJM-native
# hourly demand from s3://data.sb/pjm/hourly_demand/utilities/.
# Only the four IOU transmission zones have NITS rates: bge, dpl, pepco, poted.
# Co-ops and municipals share the zone of their host IOU.
# Years with NITS data: 2021-2025.
# =============================================================================

# IOU utilities that have direct NITS zone mappings.
pjm_bulk_tx_utilities := "bge dpl pepco poted"
pjm_bulk_tx_years := "2021 2022 2023 2024 2025"

# Generate bulk TX MC for one utility and one year.
#
#   just -f md/Justfile create-bulk-tx-mc-data bge 2025
#   just -f md/Justfile create-bulk-tx-mc-data bge 2025 --upload
create-bulk-tx-mc-data utility_arg year_arg *extra_args:
    cd {{ path_repo }} && uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_bulk_tx_mc.py \
      --iso pjm \
      --utility {{ utility_arg }} \
      --year {{ year_arg }} \
      {{ extra_args }}

# Generate bulk TX MC for all four IOU utilities across all available NITS years.
#
#   just -f md/Justfile create-bulk-tx-mc-data-all
#   just -f md/Justfile create-bulk-tx-mc-data-all --upload
create-bulk-tx-mc-data-all *extra_args:
    #!/usr/bin/env bash
    set -euo pipefail
    for utility in {{ pjm_bulk_tx_utilities }}; do
        for year in {{ pjm_bulk_tx_years }}; do
            echo ">> Generating PJM bulk TX MC: utility=${utility} year=${year}" >&2
            cd {{ path_repo }} && uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_bulk_tx_mc.py \
              --iso pjm \
              --utility "${utility}" \
              --year "${year}" \
              {{ extra_args }}
        done
    done
    echo ">> Done: all MD bulk TX MC" >&2
