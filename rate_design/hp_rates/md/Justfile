# MD heat pump rate design tasks.
# Thin wrapper: sets state defaults, loads state.env, imports shared recipes.
#
# Usage (from rate_design/hp_rates/):
#   just -f md/Justfile create-supply-energy-mc bge 2023
#   just -f md/Justfile create-bulk-tx-mc-data bge 2025
#   just -f md/Justfile create-bulk-tx-mc-data-all
#   just -f md/Justfile create-dist-and-sub-tx-mc-data        # uses state.env UTILITY
# Or via dispatch:
#   just s md create-bulk-tx-mc-data bge 2025
#   just s md create-dist-and-sub-tx-mc-data

set dotenv-path := "state.env"

state := env_var_or_default('STATE', 'md')
utility := env_var_or_default('UTILITY', 'bge')

import '../Justfile'

# =============================================================================
# MD-only: tariff fetching
#
# fetch-default-electric-tariffs: fetches both the Genability snapshot (for the
#   revenue-requirement pipeline) and URDB v7 delivery + supply JSONs (for CAIRO).
#   Snapshot → config/rev_requirement/top-ups/default_tariffs/
#   URDB     → config/tariffs/electric/{utility}_default.json
#              config/tariffs/electric/{utility}_default_supply.json
#
# fetch-gas-tariffs: fetches gas tariffs from RateAcuity as URDB v7 JSON.
#   Requires rateacuity_tariffs.yaml and rate_acuity_utility_names in utility_codes.py.
#   Output → config/tariffs/gas/{tariff_key}.json
# =============================================================================

fetch-default-electric-tariffs effective_date="2025-01-01":
    uv run python {{ path_repo }}/utils/pre/rev_requirement/fetch_electric_tariffs_genability.py \
      "{{ path_genability_yaml }}" \
      "{{ path_genability }}/default_tariffs" \
      --state "{{ state_upper }}" \
      --effective-date "{{ effective_date }}" \
      --urdb \
      --path-urdb-dir "{{ path_tariffs_electric }}"

path_rateacuity_phase2_yaml := path_tariffs_gas / "rateacuity_tariffs_chesapeake_phase2.yaml"
path_add_pgc := path_repo / "utils/data_prep/tariffs/add_pgc_to_gas_urdb.py"
path_ugi_pgc_csv := path_tariffs_gas / "ugi_central_penn_pgc.csv"
path_easton_pgc_csv := path_tariffs_gas / "easton_muni_pgc.csv"
tariff_year := "2025"

fetch-gas-tariffs:
    uv run python {{ path_repo }}/utils/pre/fetch_gas_tariffs_rateacuity.py \
      "{{ path_rateacuity_yaml }}" \
      "{{ path_tariffs_gas }}"
    just fetch-chesapeake-gas-phase2
    just split-chesapeake-gas-tariffs
    just fetch-ugi-pgc
    just add-pgc-to-gas-urdbs

# Add annual-average commodity (PGC) rates to the distribution-only UGI and
# Easton URDB JSONs.  Reads from the *_dist.json files (never modified) and
# writes the combined result to the standard *_residential.json names.
# Idempotent: safe to re-run any time after updating PGC CSVs.
# just -f md/Justfile add-pgc-to-gas-urdbs
add-pgc-to-gas-urdbs:
    uv run python {{ path_add_pgc }} \
      --path-urdb-dist "{{ path_tariffs_gas }}/ugi_central_penn_residential_dist.json" \
      --path-urdb-out  "{{ path_tariffs_gas }}/ugi_central_penn_residential.json" \
      --path-pgc       "{{ path_ugi_pgc_csv }}" \
      --pgc-col        price_to_compare_per_ccf \
      --year           {{ tariff_year }}
    uv run python {{ path_add_pgc }} \
      --path-urdb-dist "{{ path_tariffs_gas }}/easton_muni_residential_dist.json" \
      --path-urdb-out  "{{ path_tariffs_gas }}/easton_muni_residential.json" \
      --path-pgc       "{{ path_easton_pgc_csv }}" \
      --pgc-col        total_supply_per_ccf \
      --year           {{ tariff_year }}

# Fetch UGI Central Penn residential price-to-compare (commodity rate) from
# pennsylvaniaenergy.com/pricing-history/ and write to ugi_central_penn_pgc.csv.
#
# The site publishes a rolling ~24-month history; requesting dates outside that
# window raises an error. Data availability starts roughly 24 months before today.
#
#   just -f md/Justfile fetch-ugi-pgc               # default: 2024-01 to current month
#   just -f md/Justfile fetch-ugi-pgc 2025-01 2025-12
ugi_pgc_default_start := "2024-01"
ugi_pgc_default_end := `date +%Y-%m`

fetch-ugi-pgc start=ugi_pgc_default_start end=ugi_pgc_default_end:
    uv run python {{ path_repo }}/utils/data_prep/tariffs/fetch_ugi_pgc.py \
      --start "{{ start }}" \
      --end "{{ end }}" \
      --path-output "{{ path_ugi_pgc_csv }}"

fetch-chesapeake-gas-phase2:
    uv run python {{ path_repo }}/utils/pre/fetch_gas_tariffs_rateacuity.py \
      "{{ path_rateacuity_phase2_yaml }}" \
      "{{ path_tariffs_gas }}" \
      --year 2027

split-chesapeake-gas-tariffs:
    uv run python {{ path_repo }}/utils/data_prep/tariffs/split_chesapeake_gas_tariffs.py \
      --path-res1-csv "{{ path_tariffs_gas }}/chesapeake_utilities_res1.csv" \
      --path-res2-csv "{{ path_tariffs_gas }}/chesapeake_utilities_res2.csv" \
      --path-res1-phase2-csv "{{ path_tariffs_gas }}/chesapeake_utilities_res1_phase2.csv" \
      --path-res2-phase2-csv "{{ path_tariffs_gas }}/chesapeake_utilities_res2_phase2.csv" \
      --output-dir "{{ path_tariffs_gas }}"

# =============================================================================
# MD-only: gas tariff maps
#
# Gas tariff maps are partitioned by electric utility (output:
# tariff_maps/gas/<electric_utility>_u00.csv and _u02.csv). MD has 8 modeled
# gas utilities (bge, washington_gas, columbia_gas_md, chesapeake_utilities,
# sandpiper, elkton_gas, ugi_central_penn, easton_muni) served across 6
# modeled electric utilities; somerset_rec is outside the gas-map electric list.
#
# Chesapeake-territory RES-1/RES-2 split reads load_curve_annual from the raw
# NREL release (passed automatically by the shared create-gas-tariff-map recipe).
#
# Shortcuts (upgrade 00 only — quick per-utility run):
#   just -f md/Justfile map-gas-bge
#   just -f md/Justfile map-gas-all-utilities
#
# Full batch (upgrades 00 + 02):
#   just -f md/Justfile create-gas-tariff-maps-md-all
# =============================================================================

# Electric utilities for which gas tariff maps are generated (covers all 8
# modeled MD gas utilities across these 6 electric service territories).
md_electric_utilities := "bge pepco dpl poted smeco choptank"

# Per-utility shortcuts (upgrade 00). Mirror NY map-gas-<name> convention.
map-gas-bge:
    just create-gas-tariff-map bge 00 {{ path_tariff_maps }}/gas

map-gas-pepco:
    just create-gas-tariff-map pepco 00 {{ path_tariff_maps }}/gas

map-gas-dpl:
    just create-gas-tariff-map dpl 00 {{ path_tariff_maps }}/gas

map-gas-poted:
    just create-gas-tariff-map poted 00 {{ path_tariff_maps }}/gas

map-gas-smeco:
    just create-gas-tariff-map smeco 00 {{ path_tariff_maps }}/gas

map-gas-choptank:
    just create-gas-tariff-map choptank 00 {{ path_tariff_maps }}/gas

# Run upgrade-00 gas tariff maps for all 6 MD electric utilities.
map-gas-all-utilities:
    mkdir -p {{ path_tariff_maps }}/gas
    just map-gas-bge
    just map-gas-pepco
    just map-gas-dpl
    just map-gas-poted
    just map-gas-smeco
    just map-gas-choptank

# Full batch: upgrades 00 + 02 for all 6 MD electric utilities.
create-gas-tariff-maps-md-all:
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p {{ path_tariff_maps }}/gas
    for utility in {{ md_electric_utilities }}; do
        for upgrade in 00 02; do
            echo ">> MD gas tariff map: utility=${utility} upgrade=${upgrade}" >&2
            just create-gas-tariff-map "${utility}" "${upgrade}" "{{ path_tariff_maps }}/gas"
        done
    done
    echo ">> Done: all MD gas tariff maps" >&2

# =============================================================================
# MD-only: ISO-native load source for sub-TX/DX marginal costs
#
# MD reads PJM-native utility loads (data/pjm/hourly_demand/) instead of the
# shared EIA default. Layout: utility={slug}/year=YYYY/month=MM/data.parquet,
# which the ISO-native path handling in generate_utility_tx_dx_mc.py reads
# without a region= filter.
# =============================================================================

path_s3_utility_loads := "s3://data.sb/pjm/hourly_demand/utilities/"

# =============================================================================
# MD-only: supply energy marginal costs (PJM LMP)
# =============================================================================

# Available years from PJM LMP download (2018-2025, excluding incomplete 2026).
pjm_lmp_years := "2018 2019 2020 2021 2022 2023 2024 2025"

# All MD utilities (canonical std_names) and their PJM zones (IOUs + co-ops + municipals).
# IOUs: bge (BGE), pepco (PEPCO), dpl (DPL), poted (APS)
# Co-ops: smeco (PEPCO), choptank (DPL), somerset_rec (APS)
# Municipals: hagerstown_muni (APS), easton_muni (DPL), berlin_muni (DPL)
pjm_utilities := "bge pepco dpl poted smeco choptank somerset_rec hagerstown_muni easton_muni berlin_muni"

# Generate supply energy MC for one MD utility and one year.
#
#   just -f md/Justfile create-supply-energy-mc bge 2023
# just -f md/Justfile create-supply-energy-mc bge 2023 --upload
create-supply-energy-mc utility year *extra_args:
    uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_supply_energy_mc.py \
      --iso pjm \
      --utility {{ utility }} \
      --year {{ year }} \
      {{ extra_args }}

# Generate supply energy MC for one utility across all available years.
#
#   just -f md/Justfile create-supply-energy-mc-all-years bge
# just -f md/Justfile create-supply-energy-mc-all-years bge --upload
create-supply-energy-mc-all-years utility *extra_args:
    #!/usr/bin/env bash
    set -euo pipefail
    for year in {{ pjm_lmp_years }}; do
        echo ">> Generating PJM supply energy MC: utility={{ utility }} year=${year}" >&2
        uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_supply_energy_mc.py \
          --iso pjm \
          --utility {{ utility }} \
          --year "${year}" \
          {{ extra_args }}
    done
    echo ">> Done: {{ utility }} all years" >&2

# Generate supply energy MC for all MD utilities for one year.
#
#   just -f md/Justfile create-supply-energy-mc-all 2023
# just -f md/Justfile create-supply-energy-mc-all 2023 --upload
create-supply-energy-mc-all year *extra_args:
    #!/usr/bin/env bash
    set -euo pipefail
    for utility in {{ pjm_utilities }}; do
        echo ">> Generating PJM supply energy MC: utility=${utility} year={{ year }}" >&2
        uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_supply_energy_mc.py \
          --iso pjm \
          --utility "${utility}" \
          --year {{ year }} \
          {{ extra_args }}
    done
    echo ">> Done: all utilities year={{ year }}" >&2

# Generate supply energy MC for ALL utilities across ALL available years.
# This is the full backfill. Runs sequentially utility-by-utility, year-by-year.
#
#   just -f md/Justfile create-supply-energy-mc-full-backfill
# just -f md/Justfile create-supply-energy-mc-full-backfill --upload
create-supply-energy-mc-full-backfill *extra_args:
    #!/usr/bin/env bash
    set -euo pipefail
    for utility in {{ pjm_utilities }}; do
        for year in {{ pjm_lmp_years }}; do
            echo ">> Generating PJM supply energy MC: utility=${utility} year=${year}" >&2
            uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_supply_energy_mc.py \
              --iso pjm \
              --utility "${utility}" \
              --year "${year}" \
              {{ extra_args }}
        done
    done
    echo ">> Done: full backfill" >&2

# =============================================================================
# MD-only: bulk transmission marginal costs (PJM NITS + PCAF)
#
# PJM bulk TX is zone-level: one NITS rate per transmission zone, peak hours
# identified from zone-aggregate load. Each MD utility maps 1:1 to a zone
# (data/pjm/zone_mapping/csv/pjm_utility_zone_mapping.csv), and the utility-
# level load on S3 IS the full zone load. So we just run the same calculation
# for each utility — all utilities in the same zone produce the same output.
#
# Zone → utilities:
#   BGE   → bge
#   DPL   → dpl, choptank, easton_muni, berlin_muni
#   PEPCO → pepco, smeco
#   APS   → poted, somerset_rec, hagerstown_muni
#
# Uses NITS rates from data/pjm/bulk_tx/nits/nits_rates.csv and PJM-native
# hourly demand from s3://data.sb/pjm/hourly_demand/utilities/.
# Years with NITS data: 2021-2025.
# =============================================================================

pjm_bulk_tx_utilities := "bge dpl pepco poted smeco choptank somerset_rec hagerstown_muni easton_muni berlin_muni"
# Expand as more years are uploaded to s3://data.sb/pjm/hourly_demand/utilities/.
pjm_bulk_tx_years := "2025"

# Generate bulk TX MC for one utility and one year.
#
#   just -f md/Justfile create-bulk-tx-mc-data bge 2025
# just -f md/Justfile create-bulk-tx-mc-data smeco 2025 --upload
create-bulk-tx-mc-data utility_arg year_arg *extra_args:
    cd {{ path_repo }} && uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_bulk_tx_mc.py \
      --iso pjm \
      --utility {{ utility_arg }} \
      --year {{ year_arg }} \
      {{ extra_args }}

# Generate bulk TX MC for all MD utilities across all available NITS years.
#
# just -f md/Justfile create-bulk-tx-mc-data-all --upload
create-bulk-tx-mc-data-all *extra_args:
    #!/usr/bin/env bash
    set -euo pipefail
    for utility in {{ pjm_bulk_tx_utilities }}; do
        for year in {{ pjm_bulk_tx_years }}; do
            echo ">> Generating PJM bulk TX MC: utility=${utility} year=${year}" >&2
            cd {{ path_repo }} && uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_bulk_tx_mc.py \
              --iso pjm \
              --utility "${utility}" \
              --year "${year}" \
              {{ extra_args }}
        done
    done
    echo ">> Done: all MD bulk TX MC ($(echo {{ pjm_bulk_tx_utilities }} | wc -w) utilities × $(echo {{ pjm_bulk_tx_years }} | wc -w) years)" >&2

# =============================================================================
# MD-only: supply capacity marginal costs (PJM RPM + 5CP)
# =============================================================================

# Years with both an RPM calendar-year blend and a published summer 5CP set.
# 5CP data covers summers 2021-2025; RPM covers DY 2018/19-2026/27. The binding
# constraint is the 5CP summer, so capacity MC is available for 2021-2025.
pjm_capacity_years := "2021 2022 2023 2024 2025"

# Generate supply capacity MC for one MD utility and one year.
#
#   just -f md/Justfile create-supply-capacity-mc bge 2025
# just -f md/Justfile create-supply-capacity-mc bge 2025 --upload
create-supply-capacity-mc utility year *extra_args:
    uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_supply_capacity_mc.py \
      --iso pjm \
      --utility {{ utility }} \
      --year {{ year }} \
      {{ extra_args }}

# Generate supply capacity MC for one utility across all available years.
#
#   just -f md/Justfile create-supply-capacity-mc-all-years bge
# just -f md/Justfile create-supply-capacity-mc-all-years bge --upload
create-supply-capacity-mc-all-years utility *extra_args:
    #!/usr/bin/env bash
    set -euo pipefail
    for year in {{ pjm_capacity_years }}; do
        echo ">> Generating PJM supply capacity MC: utility={{ utility }} year=${year}" >&2
        uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_supply_capacity_mc.py \
          --iso pjm \
          --utility {{ utility }} \
          --year "${year}" \
          {{ extra_args }}
    done
    echo ">> Done: {{ utility }} all years" >&2

# Generate supply capacity MC for all MD utilities for one year.
#
#   just -f md/Justfile create-supply-capacity-mc-all 2025
# just -f md/Justfile create-supply-capacity-mc-all 2025 --upload
create-supply-capacity-mc-all year *extra_args:
    #!/usr/bin/env bash
    set -euo pipefail
    for utility in {{ pjm_utilities }}; do
        echo ">> Generating PJM supply capacity MC: utility=${utility} year={{ year }}" >&2
        uv run python {{ path_repo }}/utils/data_prep/marginal_costs/generate_supply_capacity_mc.py \
          --iso pjm \
          --utility "${utility}" \
          --year {{ year }} \
          {{ extra_args }}
    done
    echo ">> Done: all utilities year={{ year }}" >&2

# Generate supply capacity MC for ALL utilities across ALL available years.
# This is the full backfill. Runs sequentially utility-by-utility, year-by-year.
#
#   just -f md/Justfile create-supply-capacity-mc-full-backfill
# just -f md/Justfile create-supply-capacity-mc-full-backfill --upload
create-supply-capacity-mc-full-backfill *extra_args:
    #!/usr/bin/env bash
    set -euo pipefail
    for utility in {{ pjm_utilities }}; do
        for year in {{ pjm_capacity_years }}; do
            echo ">> Generating PJM supply capacity MC: utility=${utility} year=${year}" >&2
