STATE=md
REGION=pjm
YEAR=2025
DIST_LOAD_YEAR=2025
UPSTREAM_HOURS=100
UTILITIES=bge
# MC_TABLE defaults to config/marginal_costs/md_marginal_costs_2025.csv (computed
# from STATE+YEAR in the shared Justfile), so it is intentionally not set here.
# Polars temp dir under $HOME avoids shared /ebs/tmp ownership conflicts.
POLARS_TEMP_DIR=$HOME/.polars_tmp
