STATE=ri
REGION=isone
CAMBIUM_BA=p133
YEAR=2025
MC_TABLE=/ebs/home/alex_switch_box/rate-design-platform/rate_design/hp_rates/ri/config/marginal_costs/ri_marginal_costs_2025.csv
REVENUE_CSV_FILENAME=revenue_requirements.csv
UPSTREAM_HOURS=100
UTILITIES=rie
SUPPLY_ENERGY_MC=s3://data.sb/switchbox/marginal_costs/ri/supply/energy/utility=rie/year=2025/data.parquet
SUPPLY_CAPACITY_MC=s3://data.sb/switchbox/marginal_costs/ri/supply/capacity/utility=rie/year=2025/data.parquet
SUPPLY_ANCILLARY_MC=s3://data.sb/switchbox/marginal_costs/ri/supply/ancillary/utility=rie/year=2025/data.parquet
BULK_TX_MC=s3://data.sb/switchbox/marginal_costs/ri/bulk_tx/utility=rie/year=2025/data.parquet
# Use ResStock monthly loads (not EIA-861 annual kWh) for revenue topups
# calculation in compute-rr, capturing monthly rate×load covariance.
USE_RESSTOCK_LOADS=true
# Runs 1-4 use the actual utility rate structure (seasonal quarterly flat
# for RIE) instead of a single flattened volumetric rate.
BASE_TARIFF_PATTERN=default
# Polars temp dir under $HOME avoids shared /ebs/tmp ownership conflicts.
POLARS_TEMP_DIR=$HOME/.polars_tmp
