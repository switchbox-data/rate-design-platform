# RI heat pump rate design tasks.
# Thin wrapper: sets state defaults, loads state.env, imports shared recipes.
#
# Usage (from rate_design/hp_rates/):
#   just -f ri/Justfile all-pre
#   just -f ri/Justfile run-all-sequential
# Or via dispatch:
#   just s ri all-pre

set dotenv-path := "state.env"

state := env_var_or_default('STATE', 'ri')
utility := env_var_or_default('UTILITY', 'rie')

import '../Justfile'

# =============================================================================
# RI-only: gas tariff fetch
# =============================================================================

fetch-gas-tariffs:
    uv run python {{ path_repo }}/utils/pre/fetch_gas_tariffs_rateacuity.py "{{ path_rateacuity_yaml }}" "{{ path_tariffs_gas }}"

# =============================================================================
# RI-only: post-run LMI discounts
# =============================================================================

path_cpi_s3 := "s3://data.sb/fred/cpi/"

# Apply RI LIDR+ discounts to CAIRO run-bill CSVs (standalone, writes new CSV files).
# participation_rates is a space-separated list, e.g. "1.0 0.4" for p100 and p40.
apply-ri-lmi-discounts run_dir run_state run_utility fpl_year cpi_s3_path participation_rates="1.0" rider="false":
    uv run python {{ path_repo }}/utils/post/apply_ri_lmi_discounts_to_bills.py \
      --run-dir "{{ run_dir }}" \
      --state {{ run_state }} \
      --utility {{ run_utility }} \
      --fpl-year {{ fpl_year }} \
      --cpi-s3-path "{{ cpi_s3_path }}" \
      --participation-rates {{ participation_rates }} \
      {{ if rider == "true" { "--rider" } else { "" } }} \
      --upload

# Build RI master bills with integrated LMI discount columns for one or more
# participation rates in a single pass. Defaults to both p100 and p40.
build-master-bills-with-lmi batch run_delivery run_supply *script_args:
    just build-master-bills "{{ batch }}" "{{ run_delivery }}" "{{ run_supply }}" \
      --calculate-lmi \
      --lmi-fpl-year 2025 \
      --lmi-cpi-s3-path "{{ path_cpi_s3 }}" \
      --lmi-participation-rates 1.0 0.4 \
      --lmi-participation-mode uniform \
      --lmi-seed 42 \
      {{ script_args }}

# =============================================================================
# RI-only: bulk transmission marginal cost generation (AESC PTF)
# =============================================================================

tx_mc_year := env_var_or_default('TX_MC_YEAR', '2025')
tx_load_year := env_var_or_default('TX_LOAD_YEAR', tx_mc_year)

create-bulk-tx-mc-data:
    cd {{ path_repo }} && uv run python {{ path_repo }}/utils/pre/marginal_costs/generate_bulk_tx_mc.py \
      --iso isone \
      --utility {{ utility }} \
      --year {{ tx_mc_year }} \
      --load-year {{ tx_load_year }} \
      --upload

# =============================================================================
# RI-only: supply marginal cost generation (ISO-NE)
# =============================================================================

create-supply-energy-mc:
    uv run python {{ path_repo }}/utils/pre/marginal_costs/generate_supply_energy_mc.py \
      --iso isone \
      --utility {{ utility }} \
      --zone RI \
      --year {{ year }} \
      --upload

create-supply-ancillary-mc:
    uv run python {{ path_repo }}/utils/pre/marginal_costs/generate_supply_ancillary_mc.py \
      --utility {{ utility }} \
      --zone RI \
      --year {{ year }} \
      --upload

create-supply-capacity-mc:
    uv run python {{ path_repo }}/utils/pre/marginal_costs/generate_supply_capacity_mc.py \
      --iso isone \
      --utility {{ utility }} \
      --zone RI \
      --year {{ year }} \
      --upload

create-supply-mc-data:
    #!/usr/bin/env bash
    set -euo pipefail
    echo ">> Generating ISO-NE supply energy MC" >&2
    just create-supply-energy-mc
    echo ">> Generating ISO-NE supply ancillary MC" >&2
    just create-supply-ancillary-mc
    echo ">> Generating ISO-NE supply capacity MC (FCA)" >&2
    just create-supply-capacity-mc
    echo ">> Supply MC data generation completed" >&2
