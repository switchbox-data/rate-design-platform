        --path_s3 "{{ path_s3_parquet }}" \
        --state "{{ state }}" \
        --upgrade_id "{{ upgrade_id }}" \
        --input_release "{{ input_release }}" \
        --output_release "{{ output_release }}" \
        --k "{{ k }}" \
        --update_MF "{{ update_MF }}" \
        --update_other_fuel_types "{{ update_other_fuel_types }}"

adjust-mf-electricity state input_release output_release upgrade_ids:
    uv run python "{{ path_local_repo }}/utils/pre/adjust_mf_electricity.py" \
        --path_s3 "{{ path_s3_parquet }}" \
        --state "{{ state }}" \
        --input_release "{{ input_release }}" \
        --output_release "{{ output_release }}" \
        --upgrade_ids "{{ upgrade_ids }}"

adjust-mf-electricity-NY-upgrade-00:
