# ResStock metadata pipeline: download, identify HP customers, heating type, assign utilities (NY).
#
# Can be invoked from any directory — `set working-directory` ensures all shell
# commands run from this file's directory, so relative paths (e.g. config.yaml)
# always resolve correctly.
#
# Usage (from anywhere):
#   just -f data/resstock/Justfile status                           # provenance / data status
#   just -f data/resstock/Justfile status --state NY --location ebs # check EBS for NY only
#   just -f data/resstock/Justfile fetch NY
#   just -f data/resstock/Justfile fetch RI
#   just -f data/resstock/Justfile test-download NY
#   just -f data/resstock/Justfile resstock-identify-hp-customers NY
#   just -f data/resstock/Justfile resstock-identify-hp-customers RI
#   just -f data/resstock/Justfile assign-utility-ny res_2024_amy2018_2 00
#
# Or from within data/resstock/:
#   just run-pipeline NY --upgrade-ids 0 2

# All shell commands (backtick variable assignments and recipe bodies) run from
# this directory, regardless of where `just` is invoked.  This means relative
# paths like "config.yaml" always refer to data/resstock/config.yaml.
set working-directory := "."

path_local_repo := `git rev-parse --show-toplevel`

# ── Read defaults from config.yaml (single source of truth) ──────────────────
# Because working-directory is set above, open('config.yaml') always resolves
# to data/resstock/config.yaml regardless of how just is invoked.

resstock_release_year := `uv run python -c "import yaml; c=yaml.safe_load(open('config.yaml'))['resstock']; print(c['release_year'])"`
resstock_weather_file := `uv run python -c "import yaml; c=yaml.safe_load(open('config.yaml'))['resstock']; print(c['weather_file'])"`
resstock_release_version := `uv run python -c "import yaml; c=yaml.safe_load(open('config.yaml'))['resstock']; print(c['release_version'])"`
resstock_upgrade_ids := `uv run python -c "import yaml; c=yaml.safe_load(open('config.yaml'))['resstock']; print(' '.join(c['upgrade_ids']))"`
resstock_upgrade_ids_padded := `uv run python -c "import yaml; c=yaml.safe_load(open('config.yaml'))['resstock']; print(' '.join(u.zfill(2) for u in c['upgrade_ids']))"`
path_s3_parquet := `uv run python -c "import yaml; c=yaml.safe_load(open('config.yaml'))['paths']; print(c['s3_dir'])"`
path_local_parquet := `uv run python -c "import yaml; c=yaml.safe_load(open('config.yaml'))['paths']; print(c['output_dir'])"`
path_s3_pums := `uv run python -c "import yaml; c=yaml.safe_load(open('config.yaml'))['paths']; print(c['s3_pums_dir'])"`

pums_survey := `uv run python -c "import yaml; c=yaml.safe_load(open('config.yaml'))['pums']; print(c['survey'])"`
pums_year := `uv run python -c "import yaml; c=yaml.safe_load(open('config.yaml'))['pums']; print(c['year'])"`

resstock_release := "res_" + resstock_release_year + "_" + resstock_weather_file + "_" + resstock_release_version
resstock_release_sb := resstock_release + "_sb"

################################################################################
# Complete, all-in-one recipes (all via main.py)
################################################################################

# Run the full _sb release pipeline for one or more states.
# Covers: fetch → clone to _sb → metadata transforms → non-HP approximation
#         → MF electricity adjustment → utility assignment → monthly loads → upload.
# All steps are enabled by default; pass any main.py flag in args to override.
#
# Polygon filenames and add-vulnerability-columns default from state_configs.yaml;
# override with CLI flags if needed.
#
# Crash recording: if the pipeline exits non-zero (including OOM kill / SIGKILL
# exit code 137), the wrapper calls `manifest --mark-crashed --exit-code <N>` to
# retroactively mark the in_progress run as crashed with the actual exit code.
# This ensures the manifest always reflects the true outcome, even when Python
# cannot catch the signal.  See also: `just -f data/resstock/Justfile mark-crashed`.
#
# Examples:
#   just -f data/resstock/Justfile run-pipeline NY \
#       --upgrade-ids 0 2
#   just -f data/resstock/Justfile run-pipeline NY \
#       --upgrade-ids 0 2 \
#       --electric-poly-filename ny_electric_utilities_20260309.csv \
#       --gas-poly-filename ny_gas_utilities_20260309.csv
#   just -f data/resstock/Justfile run-pipeline RI \
#       --upgrade-ids 0 2
#   just -f data/resstock/Justfile run-pipeline NY --sample 10 \
# --upgrade-ids 0 2
run-pipeline state *args:
    #!/usr/bin/env bash
    set -uo pipefail
    cd "{{ path_local_repo }}"
    uv run python -m data.resstock.main \
        --state "{{ state }}" \
        {{ args }}
    rc=$?
    if [ $rc -ne 0 ]; then
        echo "Pipeline exited with code $rc." >&2
        uv run python -m data.resstock.manifest --mark-crashed --exit-code "$rc"
    fi
    exit $rc

# Full NY _sb release pipeline for upgrades 0 and 2.
# Polygon filenames default from state_configs.yaml.
create-sb-release-for-upgrade-02-NY:
    cd "{{ path_local_repo }}" && uv run python -m data.resstock.main \
        --state NY \
        --upgrade-ids 0 2

# Full RI _sb release pipeline for upgrades 0 and 2.
# add-vulnerability-columns defaults to False for RI via state_configs.yaml.
create-sb-release-for-upgrade-02-RI:
    cd "{{ path_local_repo }}" && uv run python -m data.resstock.main \
        --state RI \
        --upgrade-ids 0 2

################################################################################
# Status / provenance
################################################################################

# Check provenance of ResStock data on EBS and S3.
#
# Examples:
#   just -f data/resstock/Justfile status                                     # default release, both locations
#   just -f data/resstock/Justfile status --release res_2024_amy2018_2        # specific release
#   just -f data/resstock/Justfile status --release res_2024_amy2018_2_sb     # _sb form also accepted
#   just -f data/resstock/Justfile status --state NY                          # only runs that touched NY
#   just -f data/resstock/Justfile status --upgrade 0 2                       # only runs for upgrade 0 or 2
#   just -f data/resstock/Justfile status --state NY --upgrade 2              # combine filters
#   just -f data/resstock/Justfile status --variant sb                        # only the _sb (modified) release
#   just -f data/resstock/Justfile status --location ebs                      # skip S3, check local only
#   just -f data/resstock/Justfile status --location s3                       # skip EBS, check S3 only
# just -f data/resstock/Justfile status --history 5 -v                      # last 5 runs, verbose
status *args:
    cd "{{ path_local_repo }}" && uv run python -m data.resstock.manifest {{ args }}

# Mark any stale in_progress runs in the local manifest as crashed.
# Use after an unexpected kill (OOM, SIGKILL, hard reboot) to clean up
# the manifest without starting a new pipeline run.  The run-pipeline
# recipe calls this automatically on non-zero exit, but this recipe
# is useful when running main.py directly or for manual cleanup.
#
# Examples:
#   just -f data/resstock/Justfile mark-crashed
# just -f data/resstock/Justfile mark-crashed --exit-code 137
mark-crashed *args:
    cd "{{ path_local_repo }}" && uv run python -m data.resstock.manifest --mark-crashed {{ args }}

################################################################################
# Individual recipes
################################################################################

# Download ResStock metadata and loads. Pass state: NY or RI (or both as space-separated).
fetch state:
    cd "{{ path_local_repo }}" && uv run python -m data.resstock.nrel.fetch_resstock_data \
        --state {{ state }} \
        --release-year {{ resstock_release_year }} \
        --weather-file {{ resstock_weather_file }} \
        --release-version {{ resstock_release_version }} \
        --upgrade-ids {{ resstock_upgrade_ids }} \
        --path-output-dir {{ path_local_parquet }}

# Download only load_curve_annual file type.
fetch-load-curve-annual state:
    cd "{{ path_local_repo }}" && uv run python -m data.resstock.nrel.fetch_resstock_data \
        --state {{ state }} \
        --release-year {{ resstock_release_year }} \
        --weather-file {{ resstock_weather_file }} \
        --release-version {{ resstock_release_version }} \
        --upgrade-ids {{ resstock_upgrade_ids }} \
        --path-output-dir {{ path_local_parquet }} \
        --file-types load_curve_annual

# Copy resstock data from one release to another.
copy-resstock-data release_from release_to state upgrade_ids file_types:
    uv run python "{{ path_local_repo }}/data/resstock/nrel/copy_resstock_data.py" \
    	--data_path "{{ path_s3_parquet }}" \
    	--release_from "{{ release_from }}" \
    	--release_to "{{ release_to }}" \
    	--state "{{ state }}" \
    	--upgrade_ids "{{ upgrade_ids }}" \
    	--file_types "{{ file_types }}"

copy-resstock-data-2024-amy2018-2-NY upgrade_ids file_types:
    just copy-resstock-data {{ resstock_release }} {{ resstock_release_sb }} NY "{{ upgrade_ids }}" "{{ file_types }}"

copy-resstock-data-2024-amy2018-2-RI upgrade_ids file_types:
    just copy-resstock-data {{ resstock_release }} {{ resstock_release_sb }} RI "{{ upgrade_ids }}" "{{ file_types }}"

# Verify ResStock download. Pass state (NY or RI).
test-download state:
    cd "{{ path_local_repo }}" && uv run python "{{ path_local_repo }}/tests/test_resstock_download_to_s3.py" \
        --data_path "{{ path_s3_parquet }}/" \
        --release {{ resstock_release }} \
        --state {{ state }} \
        --upgrade_id {{ resstock_upgrade_ids_padded }}

# Identify HP customers and heating type for a state. Pass state (NY or RI).
identify-hp-customers release state upgrade_ids input_filename output_filename:
    #!/usr/bin/env bash
    set -e
    if [[ "{{ release }}" != *"2024"* ]]; then
        echo "Warning: this task is only verified to work with 2024 releases."
    fi
    for upgrade_id in {{ upgrade_ids }}; do
        uv run python "{{ path_local_repo }}/data/resstock/metadata/identify_hp_customers.py" \
            --input_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state={{ state }}/upgrade=$upgrade_id" \
            --output_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state={{ state }}/upgrade=$upgrade_id" \
            --input_filename "{{ input_filename }}" \
            --output_filename "{{ output_filename }}" \
            --upgrade_id "$upgrade_id"
    done

identify-heating-type release state upgrade_ids input_filename output_filename:
    #!/usr/bin/env bash
    set -e
    if [[ "{{ release }}" != *"2024"* ]]; then
        echo "Warning: this task is only verified to work with 2024 releases."
    fi
    for upgrade_id in {{ upgrade_ids }}; do
        uv run python "{{ path_local_repo }}/data/resstock/metadata/identify_heating_type.py" \
            --input_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state={{ state }}/upgrade=$upgrade_id" \
            --output_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state={{ state }}/upgrade=$upgrade_id" \
            --input_filename "{{ input_filename }}" \
            --output_filename "{{ output_filename }}" \
            --upgrade_id "$upgrade_id"
    done

identify-natgas-connection release state upgrade_ids input_metadata_filename output_filename:
    #!/usr/bin/env bash
    set -e
    if [[ "{{ release }}" != *"2024"* ]]; then
        echo "Warning: this task is only verified to work with 2024 releases."
    fi
    for upgrade_id in {{ upgrade_ids }}; do
        uv run python "{{ path_local_repo }}/data/resstock/metadata/identify_natgas_connection.py" \
            --input_metadata_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state={{ state }}/upgrade=$upgrade_id" \
            --input_load_curve_annual_dir "{{ path_s3_parquet }}/{{ release }}/load_curve_annual/state={{ state }}/upgrade=$upgrade_id" \
            --output_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state={{ state }}/upgrade=$upgrade_id" \
            --input_metadata_filename "{{ input_metadata_filename }}" \
            --input_load_curve_annual_filename "{{ state }}_upgrade"$upgrade_id"_metadata_and_annual_results.parquet" \
            --output_filename "{{ output_filename }}"
    done

identify-hp-customers-all-upgrades state:
    just identify-hp-customers {{ resstock_release }} {{ state }} "{{ resstock_upgrade_ids_padded }}" "metadata.parquet" "metadata-sb.parquet"

identify-heating-type-all-upgrades state:
    just identify-heating-type {{ resstock_release }} {{ state }} "{{ resstock_upgrade_ids_padded }}" "metadata.parquet" "metadata-sb.parquet"

identify-natgas-connection-all-upgrades state:
    just identify-natgas-connection {{ resstock_release }} {{ state }} "{{ resstock_upgrade_ids_padded }}" "metadata.parquet" "metadata-sb.parquet"

identify-hp-and-heating-type-all-upgrades-and-natgas-connection state:
    just identify-hp-customers {{ resstock_release }} {{ state }} "{{ resstock_upgrade_ids_padded }}" "metadata.parquet" "metadata-sb.parquet"
    just identify-heating-type {{ resstock_release }} {{ state }} "{{ resstock_upgrade_ids_padded }}" "metadata-sb.parquet" "metadata-sb.parquet"
    just identify-natgas-connection {{ resstock_release }} {{ state }} "{{ resstock_upgrade_ids_padded }}" "metadata-sb.parquet" "metadata-sb.parquet"

# Identify HP customers for a state (shortcut).
resstock-identify-hp-customers state:
    just identify-hp-customers-all-upgrades {{ state }}

# Add vulnerability columns (random placeholder) to metadata-sb.parquet.

# Safe to re-run: drops pre-existing vulnerability columns before adding.
add-vulnerability-columns release state upgrade_ids input_metadata_filename output_metadata_filename pums_type pums_year:
    uv run python "{{ path_local_repo }}/data/resstock/metadata/add_vulnerability_columns.py" \
        --input_metadata_dir "{{ path_s3_parquet }}/{{ release }}/metadata/" \
        --output_metadata_dir "{{ path_s3_parquet }}/{{ release }}/metadata/" \
        --input_pums_dir "{{ path_s3_pums }}/{{ pums_type }}/{{ pums_year }}/person/" \
        --input_metadata_filename "{{ input_metadata_filename }}" \
        --output_metadata_filename "{{ output_metadata_filename }}" \
        --state "{{ state }}" \
        --upgrade_ids "{{ upgrade_ids }}"

add-vulnerability-columns-NY-all-upgrades:
    just add-vulnerability-columns {{ resstock_release }} NY "{{ resstock_upgrade_ids_padded }}" "metadata-sb.parquet" "metadata-sb.parquet" "{{ pums_survey }}" "{{ pums_year }}"

# Full NY metadata pipeline: HP customers → heating type → natural gas connection → vulnerability columns.

# Pass lmi="false" to skip vulnerability (e.g. for runs that don't need LMI discounts).
prepare-metadata-ny lmi="true":
    just identify-hp-customers {{ resstock_release }} NY "{{ resstock_upgrade_ids_padded }}" "metadata.parquet" "metadata-sb.parquet"
    just identify-heating-type {{ resstock_release }} NY "{{ resstock_upgrade_ids_padded }}" "metadata-sb.parquet" "metadata-sb.parquet"
    just identify-natgas-connection {{ resstock_release }} NY "{{ resstock_upgrade_ids_padded }}" "metadata-sb.parquet" "metadata-sb.parquet"
    just assign-utility-ny {{ resstock_release }} 00 "ny_electric_utilities_20260309.csv" "ny_gas_utilities_20260309.csv"
    {{ if lmi == "true" { "just add-vulnerability-columns " + resstock_release + " NY \"" + resstock_upgrade_ids_padded + "\" \"metadata-sb.parquet\" \"metadata-sb.parquet\" " + pums_survey + " " + pums_year } else { "echo 'Skipping vulnerability columns (lmi=false)'" } }}

# Full RI metadata pipeline: HP customers → heating type → natural gas connection.
prepare-metadata-ri:
    just identify-hp-customers {{ resstock_release }} RI "{{ resstock_upgrade_ids_padded }}" "metadata.parquet" "metadata-sb.parquet"
    just identify-heating-type {{ resstock_release }} RI "{{ resstock_upgrade_ids_padded }}" "metadata-sb.parquet" "metadata-sb.parquet"
    just identify-natgas-connection {{ resstock_release }} RI "{{ resstock_upgrade_ids_padded }}" "metadata-sb.parquet" "metadata-sb.parquet"
    just assign-utility-ri {{ resstock_release }} 00

# =============================================================================
# NY-only: polygon downloads (data prep for utility assignment)
# =============================================================================

download-ny-utility-polygons:
    just download-ny-electric-utility-polygons
    just download-ny-gas-utility-polygons

download-ny-electric-utility-polygons:
    wget -qO- --user-agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:89.0) Gecko/20100101 Firefox/89.0" "https://data.ny.gov/resource/awza-4vgu.csv" | aws s3 cp - "s3://data.sb/gis/utility_boundaries/ny_electric_utilities_`date +%Y%m%d`.csv"
    just test-ny-electric-utility-polygons-download

download-ny-gas-utility-polygons:
    wget -qO- --user-agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:89.0) Gecko/20100101 Firefox/89.0" "https://data.ny.gov/api/views/i7nm-ih89/rows.csv" | aws s3 cp - "s3://data.sb/gis/utility_boundaries/ny_gas_utilities_$(date +%Y%m%d).csv"
    just test-ny-gas-utility-polygons-download

test-ny-electric-utility-polygons-download:
    aws s3 ls "s3://data.sb/gis/utility_boundaries/" | grep "ny_electric_utilities_.*\.csv"

test-ny-gas-utility-polygons-download:
    aws s3 ls "s3://data.sb/gis/utility_boundaries/" | grep "ny_gas_utilities_.*\.csv"

# Assign electric/gas utilities to ResStock buildings (NY only). Run download-ny-utility-polygons first.
assign-utility-ny release upgrade electric_poly gas_poly:
    just download-ny-utility-polygons
    uv run python "{{ path_local_repo }}/data/resstock/utility/assign_utility_ny.py" \
        --input_metadata_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state=NY/upgrade={{ upgrade }}/" \
        --input_metadata_filename "metadata-sb.parquet" \
        --output_metadata_dir "{{ path_s3_parquet }}/{{ release }}/metadata_utility/state=NY/" \
        --output_utility_assignment_filename "utility_assignment.parquet" \
        --electric_poly_dir "s3://data.sb/gis/utility_boundaries/" \
        --gas_poly_dir "s3://data.sb/gis/utility_boundaries/" \
        --electric_poly_filename "{{ electric_poly }}" \
        --gas_poly_filename "{{ gas_poly }}"

# Assign electric/gas utilities to ResStock buildings (RI only)
assign-utility-ri release upgrade:
    uv run python "{{ path_local_repo }}/data/resstock/utility/assign_utility_ri.py" \
        --input_metadata_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state=RI/upgrade={{ upgrade }}/" \
        --input_metadata_filename "metadata-sb.parquet" \
        --output_metadata_dir "{{ path_s3_parquet }}/{{ release }}/metadata_utility/state=RI/" \
        --output_utility_assignment_filename "utility_assignment.parquet" \

# Approximate non-HP load for a state
approximate-non-hp-load state upgrade_id input_release output_release k update_MF update_other_fuel_types:
