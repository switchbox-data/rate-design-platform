# ResStock data pipeline: fetch, modify, and upload to S3.
#
# All recipes here are state-generic — they take a `state` argument and
# dispatch to the appropriate scripts.  State-specific convenience wrappers
# (e.g. NY polygon downloads, per-state shortcut recipes) live in the
# relevant rate_design/hp_rates/{state}/Justfile.
#
# Config is read from data/resstock/config.yaml and state_configs.yaml via the
# constants module CLI (data.resstock.constants).  See constants.py for
# supported config keys.
#
# Usage (from anywhere):
#   just -f data/resstock/Justfile run-pipeline NY --upgrade-ids 0 2
#   just -f data/resstock/Justfile fetch NY
#   just -f data/resstock/Justfile status --state NY --location ebs
#
# Or from within data/resstock/:
#   just run-pipeline NY --upgrade-ids 0 2

# All shell commands (backtick variable assignments and recipe bodies) run from
# this directory, regardless of where `just` is invoked.  This means relative
# paths like "config.yaml" always refer to data/resstock/config.yaml.
set working-directory := "."

path_local_repo := `git rev-parse --show-toplevel`

# ── Config from constants.py ─────────────────────────────────────────────────
# Each variable is read via the constants module CLI, which resolves keys from
# config.yaml (dotted paths), derived values (resstock_release), or module-level
# constants (path_ebs_parquet).  See data/resstock/constants.py for all keys.

[private]
_cfg := "data.resstock.constants"

resstock_release := `uv run python -m data.resstock.constants resstock_release`
resstock_release_sb := `uv run python -m data.resstock.constants resstock_release_sb`
resstock_upgrade_ids := `uv run python -m data.resstock.constants resstock.upgrade_ids`
resstock_upgrade_ids_padded := `uv run python -m data.resstock.constants upgrade_ids_padded`
path_s3_parquet := `uv run python -m data.resstock.constants paths.s3_dir`
path_local_parquet := `uv run python -m data.resstock.constants paths.output_dir`
path_s3_pums := `uv run python -m data.resstock.constants paths.s3_pums_dir`
path_s3_gis := `uv run python -m data.resstock.constants paths.s3_gis_dir`
pums_survey := `uv run python -m data.resstock.constants pums.survey`
pums_year := `uv run python -m data.resstock.constants pums.year`

################################################################################
# Full pipeline (all via main.py)
################################################################################

# Run the full _sb release pipeline for one or more states.
# Covers: fetch → clone to _sb → metadata transforms → non-HP approximation
#         → MF electricity adjustment → utility assignment → monthly loads → upload.
# All steps are enabled by default; pass any main.py flag in args to override.
#
# Polygon filenames and add-vulnerability-columns default from state_configs.yaml;
# override with CLI flags if needed.
#
# Crash recording: if the pipeline exits non-zero (including OOM kill / SIGKILL
# exit code 137), the wrapper calls `manifest --mark-crashed --exit-code <N>` to
# retroactively mark the in_progress run as crashed with the actual exit code.
# See also: `just -f data/resstock/Justfile mark-crashed`.
#
# Examples:
#   just -f data/resstock/Justfile run-pipeline NY --upgrade-ids 0 2
#   just -f data/resstock/Justfile run-pipeline "NY RI" --upgrade-ids 0 2
# just -f data/resstock/Justfile run-pipeline NY --sample 10 --upgrade-ids 0 2
run-pipeline state *args:
    #!/usr/bin/env bash
    set -uo pipefail
    cd "{{ path_local_repo }}"
    uv run python -m data.resstock.main \
        --state "{{ state }}" \
        {{ args }}
    rc=$?
    if [ $rc -ne 0 ]; then
        echo "Pipeline exited with code $rc." >&2
        uv run python -m data.resstock.manifest --mark-crashed --exit-code "$rc"
    fi
    exit $rc

################################################################################
# Status / provenance
################################################################################

# Check provenance of ResStock data on EBS and S3.
#
# Examples:
#   just -f data/resstock/Justfile status
#   just -f data/resstock/Justfile status --state NY --location ebs
# just -f data/resstock/Justfile status --history 5 -v
status *args:
    cd "{{ path_local_repo }}" && uv run python -m data.resstock.manifest {{ args }}

# Mark any stale in_progress runs in the local manifest as crashed.
# Use after an unexpected kill (OOM, SIGKILL, hard reboot) to clean up
# the manifest without starting a new pipeline run.  The run-pipeline
# recipe calls this automatically on non-zero exit.
#
# Examples:
#   just -f data/resstock/Justfile mark-crashed
# just -f data/resstock/Justfile mark-crashed --exit-code 137
mark-crashed *args:
    cd "{{ path_local_repo }}" && uv run python -m data.resstock.manifest --mark-crashed {{ args }}

################################################################################
# Individual step recipes (for debugging and partial re-runs)
#
# Each recipe corresponds to one pipeline step in main.py.  They are useful
# for re-running a single step without the full pipeline, or for debugging.
################################################################################

# ── 1. Fetch ──────────────────────────────────────────────────────────────────

# Download ResStock metadata and loads for a state (all file types).
fetch state *args:
    cd "{{ path_local_repo }}" && uv run python -m data.resstock.nrel.fetch_resstock_data \
        --state {{ state }} \
        --upgrade-ids {{ resstock_upgrade_ids }} \
        --path-output-dir {{ path_local_parquet }} \
        {{ args }}

# Download only load_curve_annual file type for a state.
fetch-load-curve-annual state:
    just fetch {{ state }} --file-types load_curve_annual

# ── 2. Copy / clone ──────────────────────────────────────────────────────────

# Copy resstock data from one release to another (S3 to S3).
copy-resstock-data release_from release_to state upgrade_ids file_types:
    uv run python "{{ path_local_repo }}/data/resstock/nrel/copy_resstock_data.py" \
        --data_path "{{ path_s3_parquet }}" \
        --release_from "{{ release_from }}" \
        --release_to "{{ release_to }}" \
        --state "{{ state }}" \
        --upgrade_ids "{{ upgrade_ids }}" \
        --file_types "{{ file_types }}"

# ── 3. Metadata transforms ───────────────────────────────────────────────────

# Identify HP customers for a state across a set of upgrade IDs.
identify-hp-customers release state upgrade_ids input_filename output_filename:
    #!/usr/bin/env bash
    set -e
    if [[ "{{ release }}" != *"2024"* ]]; then
        echo "Warning: this task is only verified to work with 2024 releases."
    fi
    for upgrade_id in {{ upgrade_ids }}; do
        uv run python "{{ path_local_repo }}/data/resstock/metadata/identify_hp_customers.py" \
            --input_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state={{ state }}/upgrade=$upgrade_id" \
            --output_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state={{ state }}/upgrade=$upgrade_id" \
            --input_filename "{{ input_filename }}" \
            --output_filename "{{ output_filename }}" \
            --upgrade_id "$upgrade_id"
    done

# Identify heating type for a state across a set of upgrade IDs.
identify-heating-type release state upgrade_ids input_filename output_filename:
    #!/usr/bin/env bash
    set -e
    if [[ "{{ release }}" != *"2024"* ]]; then
        echo "Warning: this task is only verified to work with 2024 releases."
    fi
    for upgrade_id in {{ upgrade_ids }}; do
        uv run python "{{ path_local_repo }}/data/resstock/metadata/identify_heating_type.py" \
            --input_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state={{ state }}/upgrade=$upgrade_id" \
            --output_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state={{ state }}/upgrade=$upgrade_id" \
            --input_filename "{{ input_filename }}" \
            --output_filename "{{ output_filename }}" \
            --upgrade_id "$upgrade_id"
    done

# Identify natural gas connection for a state across a set of upgrade IDs.
identify-natgas-connection release state upgrade_ids input_metadata_filename output_filename:
    #!/usr/bin/env bash
    set -e
    if [[ "{{ release }}" != *"2024"* ]]; then
        echo "Warning: this task is only verified to work with 2024 releases."
    fi
    for upgrade_id in {{ upgrade_ids }}; do
        uv run python "{{ path_local_repo }}/data/resstock/metadata/identify_natgas_connection.py" \
            --input_metadata_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state={{ state }}/upgrade=$upgrade_id" \
            --input_load_curve_annual_dir "{{ path_s3_parquet }}/{{ release }}/load_curve_annual/state={{ state }}/upgrade=$upgrade_id" \
            --output_dir "{{ path_s3_parquet }}/{{ release }}/metadata/state={{ state }}/upgrade=$upgrade_id" \
            --input_metadata_filename "{{ input_metadata_filename }}" \
            --input_load_curve_annual_filename "{{ state }}_upgrade"$upgrade_id"_metadata_and_annual_results.parquet" \
            --output_filename "{{ output_filename }}"
    done

# Shortcut: identify HP customers for a state (all upgrades, default filenames).
identify-hp-customers-all-upgrades state:
    just identify-hp-customers {{ resstock_release }} {{ state }} "{{ resstock_upgrade_ids_padded }}" "metadata.parquet" "metadata-sb.parquet"

# Shortcut: identify heating type for a state (all upgrades, default filenames).
identify-heating-type-all-upgrades state:
    just identify-heating-type {{ resstock_release }} {{ state }} "{{ resstock_upgrade_ids_padded }}" "metadata.parquet" "metadata-sb.parquet"

# Shortcut: identify natgas connection for a state (all upgrades, default filenames).
identify-natgas-connection-all-upgrades state:
    just identify-natgas-connection {{ resstock_release }} {{ state }} "{{ resstock_upgrade_ids_padded }}" "metadata.parquet" "metadata-sb.parquet"

# Shortcut: full metadata chain (HP → heating type → natgas) for a state.
identify-all-metadata state:
    just identify-hp-customers {{ resstock_release }} {{ state }} "{{ resstock_upgrade_ids_padded }}" "metadata.parquet" "metadata-sb.parquet"
    just identify-heating-type {{ resstock_release }} {{ state }} "{{ resstock_upgrade_ids_padded }}" "metadata-sb.parquet" "metadata-sb.parquet"
    just identify-natgas-connection {{ resstock_release }} {{ state }} "{{ resstock_upgrade_ids_padded }}" "metadata-sb.parquet" "metadata-sb.parquet"

# Add vulnerability (LMI) columns for a state across a set of upgrade IDs.
add-vulnerability-columns release state upgrade_ids input_metadata_filename output_metadata_filename pums_type pums_year:
    uv run python "{{ path_local_repo }}/data/resstock/metadata/add_vulnerability_columns.py" \
        --input_metadata_dir "{{ path_s3_parquet }}/{{ release }}/metadata/" \
        --output_metadata_dir "{{ path_s3_parquet }}/{{ release }}/metadata/" \
        --input_pums_dir "{{ path_s3_pums }}/{{ pums_type }}/{{ pums_year }}/person/" \
        --input_metadata_filename "{{ input_metadata_filename }}" \
        --output_metadata_filename "{{ output_metadata_filename }}" \
        --state "{{ state }}" \
        --upgrade_ids "{{ upgrade_ids }}"

# Shortcut: add vulnerability columns for a state (all upgrades, default filenames).
add-vulnerability-columns-all-upgrades state:
    just add-vulnerability-columns {{ resstock_release }} {{ state }} "{{ resstock_upgrade_ids_padded }}" "metadata-sb.parquet" "metadata-sb.parquet" "{{ pums_survey }}" "{{ pums_year }}"

# ── 4. Load curve modifications ──────────────────────────────────────────────

# Run the non-HP load approximation for a state.
approximate-non-hp-load state upgrade_id input_release output_release k update_MF update_other_fuel_types:
    uv run python "{{ path_local_repo }}/utils/pre/approximate_non_hp_load.py" \
        --path_s3 "{{ path_s3_parquet }}" \
        --state "{{ state }}" \
        --upgrade_id "{{ upgrade_id }}" \
        --input_release "{{ input_release }}" \
        --output_release "{{ output_release }}" \
        --k "{{ k }}" \
        --update_MF "{{ update_MF }}" \
        --update_other_fuel_types "{{ update_other_fuel_types }}"

# Apply MF non-HVAC electricity adjustment for a state.
adjust-mf-electricity state input_release output_release upgrade_ids:
    uv run python "{{ path_local_repo }}/utils/pre/adjust_mf_electricity.py" \
        --path_s3 "{{ path_s3_parquet }}" \
        --state "{{ state }}" \
        --input_release "{{ input_release }}" \
        --output_release "{{ output_release }}" \
        --upgrade_ids "{{ upgrade_ids }}"

# ── 5. Monthly load curves ───────────────────────────────────────────────────

# Aggregate _sb hourly load curves into monthly for a state.
add-monthly-loads state upgrade_ids:
    uv run python "{{ path_local_repo }}/data/resstock/load_curve/add_monthly_loads.py" \
        --path-input "{{ path_local_parquet }}/{{ resstock_release_sb }}" \
        --path-output "{{ path_local_parquet }}/{{ resstock_release_sb }}" \
        --state "{{ state }}" \
        --upgrade-ids "{{ upgrade_ids }}" \
        --bsf-release "{{ resstock_release }}" \
        --workers 50

# Upload monthly load curves for a state to S3.
upload-monthly-loads state upgrade_ids:
    #!/usr/bin/env bash
    set -e
    for upgrade_id in {{ upgrade_ids }}; do
        echo "Uploading load_curve_monthly/state={{ state }}/upgrade=$upgrade_id to S3..."
        aws s3 sync \
            "{{ path_local_parquet }}/{{ resstock_release_sb }}/load_curve_monthly/state={{ state }}/upgrade=$upgrade_id/" \
            "{{ path_s3_parquet }}/{{ resstock_release_sb }}/load_curve_monthly/state={{ state }}/upgrade=$upgrade_id/" \
            --quiet
    done

# ── 6. Verification ──────────────────────────────────────────────────────────

# Verify ResStock download for a state.
test-download state:
    cd "{{ path_local_repo }}" && uv run python "{{ path_local_repo }}/tests/test_resstock_download_to_s3.py" \
        --data_path "{{ path_s3_parquet }}/" \
        --release {{ resstock_release }} \
        --state {{ state }} \
        --upgrade_id {{ resstock_upgrade_ids_padded }}
