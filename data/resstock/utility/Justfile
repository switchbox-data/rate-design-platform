# GIS pipeline: fetch electric + gas utility territories and PUMA shapefiles.
# Supports Connecticut (CT) and Maryland (MD); all states share the same local
# staging dirs (zips/, shapefiles/, csv/, parquet/) under this directory.
# Files are distinguished by their state-prefixed names (ct_*, md_*).
#
# ── CT recipes ────────────────────────────────────────────────────────────────
# Usage (from repo root or this directory):
#   just -f data/resstock/utility/Justfile fetch
#   just -f data/resstock/utility/Justfile upload
#   just -f data/resstock/utility/Justfile fetch upload      # full run
#   just -f data/resstock/utility/Justfile clean
#
# Optional flags (pass as variable overrides before the recipe name):
#   just -f ... no_overlay="--no-overlay" fetch    skip PUMA × utility overlays
#   just -f ... no_download="--no-download" fetch  re-use cached local shapefiles
#   just -f ... no_gas="--no-gas" fetch            skip gas (use if NASA NCCS is down)
#
# CT Outputs (S3):
#   s3://data.sb/gis/pumas/state=CT/
#   s3://data.sb/gis/utility_boundaries/ct_electric_utilities_<date>.csv
#   s3://data.sb/gis/utility_boundaries/ct_gas_utilities_<date>.csv
#   s3://data.sb/gis/utility_boundaries/ct_puma_elec_utility_overlay_<date>.parquet
#   s3://data.sb/gis/utility_boundaries/ct_puma_gas_utility_overlay_<date>.parquet
#
# ── MD recipes ────────────────────────────────────────────────────────────────
# Usage:
#   just -f data/resstock/utility/Justfile fetch-md
#   just -f data/resstock/utility/Justfile upload-md
#   just -f data/resstock/utility/Justfile prepare-md
#
# Optional flags:
#   just -f ... no_overlay="--no-overlay" fetch-md
#   just -f ... no_download="--no-download" fetch-md
#   just -f ... no_gas="--no-gas" fetch-md
#   just -f ... no_electric="--no-electric" fetch-md
#
# MD Outputs (S3):
#   s3://data.sb/gis/pumas/state=MD/
#   s3://data.sb/gis/utility_boundaries/md_electric_utilities_<date>.csv
#   s3://data.sb/gis/utility_boundaries/md_gas_utilities_<date>.csv
#   s3://data.sb/gis/utility_boundaries/md_puma_elec_utility_overlay_<date>.parquet
#   s3://data.sb/gis/utility_boundaries/md_puma_gas_utility_overlay_<date>.parquet

path_local_repo := `git rev-parse --show-toplevel`
path_local_base := justfile_directory()
path_local_zip := path_local_base + "/zips"
path_local_shapefiles := path_local_base + "/shapefiles"
path_local_csv := path_local_base + "/csv"
path_local_parquet := path_local_base + "/parquet"
path_s3_pumas := "s3://data.sb/gis/pumas"
path_s3_utility := "s3://data.sb/gis/utility_boundaries"

# Optional flags (override on the command line, e.g. no_overlay="--no-overlay")
no_overlay := ""
no_download := ""
no_gas := ""
no_electric := ""

# ── CT recipes ────────────────────────────────────────────────────────────────

# Download, extract, and process CT GIS boundary files into local staging dirs.
# Does NOT upload to S3; run 'upload' separately.
fetch:
    uv run python {{ path_local_repo }}/data/resstock/utility/fetch_ct_gis_boundaries.py \
        --path-local-zip        {{ path_local_zip }} \
        --path-local-shapefiles {{ path_local_shapefiles }} \
        --path-local-csv        {{ path_local_csv }} \
        --path-local-parquet    {{ path_local_parquet }} \
        --path-s3-pumas         {{ path_s3_pumas }} \
        --path-s3-utility       {{ path_s3_utility }} \
        --no-upload \
        {{ no_overlay }} \
        {{ no_download }} \
        {{ no_gas }}

# Upload local staging outputs to S3. Run 'fetch' first.
upload:
    uv run python {{ path_local_repo }}/data/resstock/utility/fetch_ct_gis_boundaries.py \
        --path-local-zip        {{ path_local_zip }} \
        --path-local-shapefiles {{ path_local_shapefiles }} \
        --path-local-csv        {{ path_local_csv }} \
        --path-local-parquet    {{ path_local_parquet }} \
        --path-s3-pumas         {{ path_s3_pumas }} \
        --path-s3-utility       {{ path_s3_utility }} \
        --no-download \
        {{ no_overlay }} \
        {{ no_gas }}

# Full pipeline: fetch then upload.
prepare: fetch upload

# Print a human-readable summary of the locally fetched CT GIS data
# (utility names, PUMA districts, utility × PUMA area fractions).
# Run 'fetch' first so the staging files exist.
show:
    uv run python {{ path_local_repo }}/data/resstock/utility/assign_utility_ct.py \
        --path-local-csv        {{ path_local_csv }} \
        --path-local-shapefiles {{ path_local_shapefiles }} \
        --path-local-parquet    {{ path_local_parquet }} \
        {{ no_overlay }}

# ── MD recipes ────────────────────────────────────────────────────────────────

# Download, extract, and process MD GIS boundary files into local staging dirs.
# Does NOT upload to S3; run 'upload-md' separately.
fetch-md:
    uv run python {{ path_local_repo }}/data/resstock/utility/fetch_utility_boundary_md.py \
        --path-local-zip        {{ path_local_zip }} \
        --path-local-shapefiles {{ path_local_shapefiles }} \
        --path-local-csv        {{ path_local_csv }} \
        --path-local-parquet    {{ path_local_parquet }} \
        --path-s3-pumas         {{ path_s3_pumas }} \
        --path-s3-utility       {{ path_s3_utility }} \
        --no-upload \
        {{ no_overlay }} \
        {{ no_download }} \
        {{ no_gas }} \
        {{ no_electric }}

# Upload MD local staging outputs to S3. Run 'fetch-md' first.
upload-md:
    uv run python {{ path_local_repo }}/data/resstock/utility/fetch_utility_boundary_md.py \
        --path-local-zip        {{ path_local_zip }} \
        --path-local-shapefiles {{ path_local_shapefiles }} \
        --path-local-csv        {{ path_local_csv }} \
        --path-local-parquet    {{ path_local_parquet }} \
        --path-s3-pumas         {{ path_s3_pumas }} \
        --path-s3-utility       {{ path_s3_utility }} \
        --no-download \
        {{ no_overlay }} \
        {{ no_gas }} \
        {{ no_electric }}

# Full MD pipeline: fetch then upload.
prepare-md: fetch-md upload-md

# ── Shared ────────────────────────────────────────────────────────────────────

# Remove all local staging directories (shared by all states).
clean:
    rm -rf {{ path_local_zip }} {{ path_local_shapefiles }} {{ path_local_csv }} {{ path_local_parquet }}
    echo "✓ Removed zips/, shapefiles/, csv/, parquet/"
