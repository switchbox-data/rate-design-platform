# ISO-NE FCM Monthly Reconfiguration Auction (MRA) clearing prices pipeline
#
# Fetch monthly clearing prices for all ISO-NE capacity zones and external
# interfaces via ISO Express CSV endpoints, write to Hive-partitioned parquet,
# and upload to S3.
#
# Run from repo root: just -f data/isone/capacity/mra/Justfile <recipe>
# Or from this dir:   just <recipe>

path_local_repo := `git rev-parse --show-toplevel`
path_local_base := justfile_directory()
path_local_parquet := path_local_base + "/parquet"
path_s3_parquet := "s3://data.sb/isone/capacity/mra/"

start_year := "2018"
end_year := "2026"

fetch:
    uv run python "{{path_local_base}}/fetch_isone_mra.py" \
        --start-year "{{start_year}}" --end-year "{{end_year}}" \
        --path-local-parquet "{{path_local_parquet}}"

validate:
    uv run python "{{path_local_base}}/validate_isone_mra.py" \
        --path-local-parquet "{{path_local_parquet}}"

prepare: fetch validate

upload:
    aws s3 sync "{{path_local_parquet}}/" "{{path_s3_parquet}}" \
        --exclude "*" --include "*.parquet"
    @echo "Uploaded to {{path_s3_parquet}}"

update:
    uv run python "{{path_local_base}}/update_isone_mra.py" \
        --path-local-parquet "{{path_local_parquet}}" \
        --path-s3-parquet "{{path_s3_parquet}}"

clean:
    rm -rf "{{path_local_parquet}}"
    @echo "Removed parquet/"
