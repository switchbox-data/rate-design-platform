# ISO-NE Ancillary data pipeline (regulation clearing prices + system load)
#
# Fetch hourly regulation clearing prices and system load from ISO-NE Web
# Services API, write to Hive-partitioned parquet, and upload to S3.
#
# Run from repo root: just -f data/isone/ancillary/Justfile <recipe>
# Or from this dir:   just <recipe>

path_local_repo := `git rev-parse --show-toplevel`
path_local_base := justfile_directory()
path_local_parquet := path_local_base + "/parquet"
path_s3_parquet := "s3://data.sb/isone/ancillary/"
start := "2018-01"
end := ""
workers := "4"

fetch:
    uv run python "{{ path_local_base }}/fetch_isone_ancillary_parquet.py" \
        --start "{{ start }}" --end "{{ end }}" \
        --path-local-parquet "{{ path_local_parquet }}" --workers "{{ workers }}"

validate:
    uv run python "{{ path_local_base }}/validate_isone_ancillary_parquet.py" \
        --path-local-parquet "{{ path_local_parquet }}"

prepare: fetch validate

upload:
    aws s3 sync "{{ path_local_parquet }}/" "{{ path_s3_parquet }}" --exclude "*" --include "*.parquet"
    @echo "Uploaded to {{ path_s3_parquet }}"

update:
    uv run python "{{ path_local_base }}/update_isone_ancillary_to_latest.py" \
        --path-local-parquet "{{ path_local_parquet }}" \
        --path-s3-parquet "{{ path_s3_parquet }}"

clean:
    rm -rf "{{ path_local_parquet }}"
    @echo "Removed parquet/"
