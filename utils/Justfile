# Resolve project root as absolute path using git

project_root := `git rev-parse --show-toplevel`

# =============================================================================
# PRE: run before any CAIRO runs
# =============================================================================
# Create scenario YAMLs from the Runs & Charts Google Sheet (requires G_* env and browser auth).
# Writes rate_design/hp_rates/<state>/config/scenarios/scenarios_<utility>.yaml.

# Pass state="" to generate for all states.
create-scenario-yamls state="":
    uv run python {{ project_root }}/utils/pre/create_scenario_yamls.py \
        {{ if state != "" { "--state " + state } else { "" } }}

# Update Google Sheet with MC path formulas for all states (NY + RI).
# Requires G_CLIENT_ID and G_CLIENT_SECRET in .env.

# After running, call create-scenario-yamls to pull the updated paths into YAMLs.
update-sheet-formulas:
    uv run python {{ project_root }}/utils/pre/update_sheet_formulas.py

# Write electric tariff map CSVs for all runs in a single scenario file.
write-tariff-maps scenario_config:
    uv run python {{ project_root }}/utils/pre/write_tariff_maps_from_scenario.py \
        --scenario-config "{{ scenario_config }}"

# Write electric tariff map CSVs for every scenario YAML in a scenarios directory.
write-tariff-maps-all scenarios_dir:
    for f in "{{ scenarios_dir }}"/*.yaml; do \
        uv run python {{ project_root }}/utils/pre/write_tariff_maps_from_scenario.py \
            --scenario-config "$f"; \
    done

# Create gas tariff map for a given electric utility.
create-gas-tariff-map metadata_path utility_assignment_path state electric_utility upgrade_id output_dir:
    uv run python {{ project_root }}/utils/pre/gas_tariff_mapper.py \
      --metadata_path "{{ metadata_path }}" \
      --utility_assignment_path "{{ utility_assignment_path }}" \
      --state "{{ state }}" \
      --upgrade_id "{{ upgrade_id }}" \
      --electric_utility "{{ electric_utility }}" \
      --output_dir "{{ output_dir }}"

# Derive seasonal TOU tariff + derivation spec. Rates are derived directly from MC
# without rescaling to any reference base rate (CAIRO precalc calibrates revenue neutrality).
# reference_tariff: optional path to a tariff JSON; when provided, only the fixed charge
# (fixedchargefirstmeter) is extracted from it. The base rate is ignored.

# Uses resstock_base + state + upgrade for hive-partitioned load scan (no globbing).
create-seasonal-tou path_supply_energy_mc path_supply_capacity_mc state utility year dist_and_sub_tx_mc_path path_utility_assignment resstock_base upgrade path_electric_utility_stats tou_tariff_key output_dir periods_yaml="" reference_tariff="" run_dir="" bulk_tx_mc_path="" has_hp="true":
    uv run python {{ project_root }}/utils/pre/derive_seasonal_tou.py \
      --path-supply-energy-mc "{{ path_supply_energy_mc }}" \
      --path-supply-capacity-mc "{{ path_supply_capacity_mc }}" \
      --state "{{ state }}" \
      --utility "{{ utility }}" \
      --year "{{ year }}" \
      --path-dist-and-sub-tx-mc "{{ dist_and_sub_tx_mc_path }}" \
      --path-utility-assignment "{{ path_utility_assignment }}" \
      --resstock-base "{{ resstock_base }}" \
      --upgrade "{{ upgrade }}" \
      --path-electric-utility-stats "{{ path_electric_utility_stats }}" \
      --tou-tariff-key "{{ tou_tariff_key }}" \
      --output-dir "{{ output_dir }}" \
      --has-hp "{{ has_hp }}" \
      {{ if periods_yaml != "" { "--periods-yaml \"" + periods_yaml + "\"" } else { "" } }} \
      {{ if reference_tariff != "" { "--reference-tariff \"" + reference_tariff + "\"" } else { "" } }} \
      {{ if run_dir != "" { "--run-dir \"" + run_dir + "\"" } else { "" } }} \
      {{ if bulk_tx_mc_path != "" { "--path-bulk-tx-mc \"" + bulk_tx_mc_path + "\"" } else { "" } }}

# Sweep TOU window widths (1-23) and write optimal tou_window_hours to periods YAML.
sweep-tou-window path_supply_energy_mc path_supply_capacity_mc state utility year dist_and_sub_tx_mc_path path_utility_assignment resstock_base upgrade path_electric_utility_stats periods_yaml="" run_dir="" bulk_tx_mc_path="" output_dir="" no_write_yaml="" has_hp="true":
    uv run python {{ project_root }}/utils/pre/derive_seasonal_tou_window.py \
      --path-supply-energy-mc "{{ path_supply_energy_mc }}" \
      --path-supply-capacity-mc "{{ path_supply_capacity_mc }}" \
      --state "{{ state }}" \
      --utility "{{ utility }}" \
      --year "{{ year }}" \
      --path-dist-and-sub-tx-mc "{{ dist_and_sub_tx_mc_path }}" \
      --path-utility-assignment "{{ path_utility_assignment }}" \
      --resstock-base "{{ resstock_base }}" \
      --upgrade "{{ upgrade }}" \
      --path-electric-utility-stats "{{ path_electric_utility_stats }}" \
      --has-hp "{{ has_hp }}" \
      {{ if periods_yaml != "" { "--periods-yaml \"" + periods_yaml + "\"" } else { "" } }} \
      {{ if run_dir != "" { "--run-dir \"" + run_dir + "\"" } else { "" } }} \
      {{ if bulk_tx_mc_path != "" { "--path-bulk-tx-mc \"" + bulk_tx_mc_path + "\"" } else { "" } }} \
      {{ if output_dir != "" { "--output-dir \"" + output_dir + "\"" } else { "" } }} \
      {{ if no_write_yaml == "true" { "--no-write-yaml" } else { "" } }}

# =============================================================================
# MIDRUN: run between CAIRO runs (uses outputs from earlier runs)
# =============================================================================

# Revenue requirement YAML outputs from CAIRO BAT results.
compute-subclass-rr run_dir scenario_config differentiated_yaml_path default_yaml_path run_num="1" group_col="has_hp" group_value_to_subclass="" base_rr_yaml="" run_dir_supply="" resstock_base="" upgrade="00":
    uv run python {{ project_root }}/utils/mid/compute_subclass_rr.py \
      --run-dir "{{ run_dir }}" \
      --run-num "{{ run_num }}" \
      --scenario-config "{{ scenario_config }}" \
      --group-col "{{ group_col }}" \
      --differentiated-yaml-path "{{ differentiated_yaml_path }}" \
      --default-yaml-path "{{ default_yaml_path }}" \
      {{ if group_value_to_subclass != "" { "--group-value-to-subclass \"" + group_value_to_subclass + "\"" } else { "" } }} \
      {{ if base_rr_yaml != "" { "--base-rr-yaml \"" + base_rr_yaml + "\"" } else { "" } }} \
      {{ if run_dir_supply != "" { "--run-dir-supply \"" + run_dir_supply + "\"" } else { "" } }} \
      {{ if resstock_base != "" { "--resstock-base \"" + resstock_base + "\"" } else { "" } }} \
      {{ if resstock_base != "" { "--upgrade \"" + upgrade + "\"" } else { "" } }}

# Seasonal discount inputs from run outputs + ResStock loads.
# Uses hive partitions (resstock_base + state + upgrade); building_ids from run metadata.
# group_col + subclass_value identify the subclass; the output filename encodes both so

# multiple subclass computations in the same run directory do not collide.
compute-seasonal-discount-inputs run_dir resstock_base state upgrade cross_subsidy_col="BAT_percustomer" output_dir="" base_tariff_json="" group_col="has_hp" subclass_value="true" group_value_to_subclass="":
    uv run python {{ project_root }}/utils/mid/compute_seasonal_discount_inputs.py \
      --run-dir "{{ run_dir }}" \
      --resstock-base "{{ resstock_base }}" \
      --state "{{ state }}" \
      --upgrade "{{ upgrade }}" \
      --cross-subsidy-col "{{ cross_subsidy_col }}" \
      --base-tariff-json "{{ base_tariff_json }}" \
      --group-col "{{ group_col }}" \
      --subclass-value "{{ subclass_value }}" \
      {{ if group_value_to_subclass != "" { "--group-value-to-subclass \"" + group_value_to_subclass + "\"" } else { "" } }} \
      {{ if output_dir != "" { "--output-dir \"" + output_dir + "\"" } else { "" } }}

# Tariff JSON creation from seasonal_discount_rate_inputs.csv.
create-seasonal-discount-tariff base_tariff_json seasonal_inputs_csv label output_path periods_yaml:
    cd "{{ project_root }}" && uv run python -m utils.mid.create_seasonal_discount_tariff \
      --base-tariff-json "{{ base_tariff_json }}" \
      --seasonal-inputs-csv "{{ seasonal_inputs_csv }}" \
      --label "{{ label }}" \
      --periods-yaml "{{ periods_yaml }}" \
      --output-path "{{ output_path }}"

# Uses hive partitions (resstock_base + state + upgrade); building_ids from run metadata.
# group_col + subclass_value identify the subclass; the output filename encodes both so

# multiple subclass computations in the same run directory do not collide.
compute-flat-discount-inputs run_dir resstock_base state upgrade cross_subsidy_col="BAT_percustomer" output_dir="" base_tariff_json="" group_col="has_hp" subclass_value="true" group_value_to_subclass="":
    uv run python {{ project_root }}/utils/mid/compute_flat_discount_inputs.py \
      --run-dir "{{ run_dir }}" \
      --resstock-base "{{ resstock_base }}" \
      --state "{{ state }}" \
      --upgrade "{{ upgrade }}" \
      --cross-subsidy-col "{{ cross_subsidy_col }}" \
      --base-tariff-json "{{ base_tariff_json }}" \
      --group-col "{{ group_col }}" \
      --subclass-value "{{ subclass_value }}" \
      {{ if group_value_to_subclass != "" { "--group-value-to-subclass \"" + group_value_to_subclass + "\"" } else { "" } }} \
      {{ if output_dir != "" { "--output-dir \"" + output_dir + "\"" } else { "" } }}

# Tariff JSON creation from flat_discount_rate_inputs.csv.
create-flat-discount-tariff base_tariff_json flat_inputs_csv label output_path:
    uv run python {{ project_root }}/utils/mid/create_flat_discount_tariff.py \
      --base-tariff-json "{{ base_tariff_json }}" \
      --flat-inputs-csv "{{ flat_inputs_csv }}" \
      --label "{{ label }}" \
      --output-path "{{ output_path }}"

# Fair-default inputs from run outputs + ResStock loads.

# group_col + subclass_value identify the target subclass.
compute-fair-default-inputs path_run_dir path_resstock_base state upgrade subclass_value cross_subsidy_col="BAT_percustomer" path_output_dir="" path_base_tariff_json="" group_col="has_hp" group_value_to_subclass="" mc_seasonal_ratio="" path_periods_yaml="" fixed_charge_floor="0.0":
    uv run python {{ project_root }}/utils/mid/compute_fair_default_inputs.py \
      --run-dir "{{ path_run_dir }}" \
      --resstock-base "{{ path_resstock_base }}" \
      --state "{{ state }}" \
      --upgrade "{{ upgrade }}" \
      --cross-subsidy-col "{{ cross_subsidy_col }}" \
      --base-tariff-json "{{ path_base_tariff_json }}" \
      --group-col "{{ group_col }}" \
      --subclass-value "{{ subclass_value }}" \
      --fixed-charge-floor "{{ fixed_charge_floor }}" \
      {{ if group_value_to_subclass != "" { "--group-value-to-subclass \"" + group_value_to_subclass + "\"" } else { "" } }} \
      {{ if path_output_dir != "" { "--output-dir \"" + path_output_dir + "\"" } else { "" } }} \
      {{ if path_periods_yaml != "" { "--periods-yaml \"" + path_periods_yaml + "\"" } else { "" } }} \
      {{ if mc_seasonal_ratio != "" { "--mc-seasonal-ratio \"" + mc_seasonal_ratio + "\"" } else { "" } }}

# Tariff JSON creation from fair_default_inputs.csv.
create-fair-default-tariff path_base_tariff_json path_inputs_csv strategy label path_output_path path_periods_yaml="" allow_infeasible="false":
    uv run python {{ project_root }}/utils/mid/create_fair_default_tariff.py \
      --base-tariff-json "{{ path_base_tariff_json }}" \
      --inputs-csv "{{ path_inputs_csv }}" \
      --strategy "{{ strategy }}" \
      --label "{{ label }}" \
      --output-path "{{ path_output_path }}" \
      {{ if path_periods_yaml != "" { "--periods-yaml \"" + path_periods_yaml + "\"" } else { "" } }} \
      {{ if allow_infeasible == "true" { "--allow-infeasible" } else { "" } }}

# Promote calibrated tariffs from run output:
# reads <run_dir>/tariff_final_config.json, converts each tariff to URDB format,

# and writes one <tariff_key>_calibrated.json per key under a destination directory.
copy-calibrated-tariff-from-run run_dir state output_dir="":
    uv run python -m utils.mid.copy_calibrated_tariff_from_run \
      --run-dir "{{ run_dir }}" \
      --state "{{ state }}" \
      {{ if output_dir != "" { "--destination-dir \"" + output_dir + "\"" } else { "" } }}
